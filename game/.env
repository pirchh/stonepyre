# ================================
# Market Simulation (stonepyre_market)
# ================================

MARKET_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/stonepyre_market
MARKET_BIND=127.0.0.1:7777
MARKET_TICK_MS=10000
MARKET_SIM_SEED=42
MARKET_LOG=info

# --- Ecosystem Bounds ---
MARKET_MIN_ACTIVE=175
MARKET_TARGET_ACTIVE=220
MARKET_MAX_ACTIVE=300

# --- IPO Controls ---
MARKET_IPO_BATCH_MAX=8

# --- Asset Path (prefix/suffix JSON) ---
MARKET_ASSETS_DIR=assets/market


# ================================
# Main HTTP Server (stonepyre_server)
# ================================

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/stonepyre_market
STONEPYRE_SERVER_BIND=127.0.0.1:8080
RUST_LOG=info

GAME_TICK_HZ=10
GAME_SNAPSHOT_HZ=10